<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    android:orientation="vertical"
    android:gravity="center"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tv_day_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center">

        <View
            android:id="@+id/dot_pending"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/status_pending"
            android:visibility="gone" />

        <View
            android:id="@+id/dot_completed"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/status_completed"
            android:visibility="gone" />

        <View
            android:id="@+id/dot_delayed"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/status_delayed"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>